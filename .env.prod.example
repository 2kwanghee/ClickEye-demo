# clickeye-web-demo 프로덕션 환경변수 템플릿
#   서버에서:  cp .env.prod.example .env.prod  후 값 채우기 (.env.prod 는 커밋 금지)

# Caddy 자동 HTTPS 대상 호스트네임 (sslip.io = IP 기반 무료 호스트네임)
DOMAIN=13.237.170.70.sslip.io

# Auth.js v5 — 리버스 프록시(Caddy) 뒤이므로 필수
AUTH_TRUST_HOST=true
AUTH_URL=https://13.237.170.70.sslip.io
# openssl rand -base64 32 로 생성한 값으로 교체
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32

NODE_ENV=production
# (데모에선 mock 라우팅 이후 사용 안 됨 — 참조 잔존 대비 기본값)
NEXT_PUBLIC_API_URL=https://13.237.170.70.sslip.io
